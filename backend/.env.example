# KAIZEN Protect - Environment Variables Template
# =====================================================
# Copia este archivo a .env y completa los valores

# === ANTHROPIC (REQUERIDO) ===
# Obtener de: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# === SUPABASE (OBLIGATORIO EN PRODUCCIÓN) ===
# Obtener de: Project Settings → API
# URL: Project Settings → General
SUPABASE_URL=https://tu-proyecto.supabase.co
# Key: Project Settings → API → anon public key
SUPABASE_KEY=
# Service Key: Project Settings → API → service_role key (solo en backend, NO expones)
SUPABASE_SERVICE_KEY=

# === STRIPE (PARA PAGOS) ===
# Obtener de: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook Secret: Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=
# Price IDs: Products → Price ID de cada producto
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_YEARLY_PRICE_ID=

# === RESEND (PARA EMAIL) ===
# Obtener de: https://resend.com/api-keys
RESEND_API_KEY=

# === CONFIGURACIÓN ===
# Dominios permitidos separados por coma (sin espacios)
CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
# URL del frontend para redirects y verificación
FRONTEND_URL=https://tu-dominio.com
# Ambiente: production o development
ENVIRONMENT=production
# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO